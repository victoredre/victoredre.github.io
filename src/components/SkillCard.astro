---
// component imports
import {Icon} from "astro-icon/components";

interface SkillCardProps {
    icon: string;
    name: string;
    description: string;
    showDescription?: boolean;
}

const {
    icon,
    name,
    description,
    showDescription = true,
} = Astro.props as SkillCardProps;

---

<div class="flex flex-col gap-4 h-skill-icon p-4 rounded-md hover:bg-gray-50 dark:hover:bg-n400 transition-colors">    <div class="w-16 h-16">
        <Icon width={80} height={80} name={icon} class="text-primary-light dark:text-primary-dark" />
    </div>
    <h3 class="text-lg font-bold">{name}</h3>
    {
        showDescription && <p class="text-n700 dark:text-n200">{description}</p>
    }
</div>
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Certificaciones - Victor Dre</title>
<style>
body{font-family:Inter,system-ui;background:#0a0a0a;color:#fff;margin:0;padding:40px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:30px}
.card{background:#151515;border:1px solid #2a2a2a;border-radius:16px;padding:20px;transition:.2s}
.card:hover{border-color:#00ff88;transform:translateY(-3px)}
.badge{display:inline-block;background:#00ff88;color:#000;font-size:11px;font-weight:700;padding:4px 8px;border-radius:6px;margin-bottom:10px}
h2{margin:0 0 6px 0} p{color:#aaa;font-size:14px}
a{color:#00ff88;text-decoration:none;font-size:13px}
</style>
</head>
<body>
<h1>🎖️ Mis Certificaciones</h1>
<p>Validables y con ID verificable</p>
<div class="grid">
  <div class="card">
    <span class="badge">FORTINET</span>
    <h2>NSE 4 - FortiOS</h2>
    <p>Network Security Expert - Firewall & VPN</p>
    <a href="#">Ver credencial →</a>
  </div>
  <div class="card">
    <span class="badge">CISCO</span>
    <h2>CCNA v7</h2>
    <p>Routing, Switching & Security Fundamentals</p>
    <a href="#">Ver credencial →</a>
  </div>
  <div class="card">
    <span class="badge">AWS</span>
    <h2>AWS Cloud Practitioner</h2>
    <p>Fundamentos de Cloud & Arquitectura</p>
    <a href="#">Ver credencial →</a>
  </div>
  <div class="card">
    <span class="badge">CYBERSECURITY</span>
    <h2>Tu cert aquí</h2>
    <p>Añade tu cert de análisis de malware / SOC</p>
    <a href="#">Ver credencial →</a>
  </div>
</div>
</body>
</html>
