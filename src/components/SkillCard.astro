---
// SkillCard.astro — Certificación con imagen clickeable
import { Icon } from "astro-icon/components";

interface SkillCardProps {
    image: string;           // URL de la imagen del certificado/badge
    name: string;
    description: string;
    showDescription?: boolean;
    credentialUrl: string;   // URL de la credencial (obligatoria ahora)
    level?: "beginner" | "intermediate" | "advanced" | "expert";
    issuer?: string;
    date?: string;
    tags?: string[];
    isVerified?: boolean;
}

const {
    image,
    name,
    description,
    showDescription = true,
    credentialUrl,
    level,
    issuer,
    date,
    tags = [],
    isVerified = false,
} = Astro.props as SkillCardProps;

const levelConfig = {
    beginner: { color: "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400", label: "Principiante" },
    intermediate: { color: "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400", label: "Intermedio" },
    advanced: { color: "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400", label: "Avanzado" },
    expert: { color: "bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400", label: "Experto" },
};
---

<div class="group relative flex flex-col gap-4 p-6 rounded-2xl bg-white dark:bg-n500 border border-gray-100 dark:border-n400 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 ease-out overflow-hidden">
    
    {/* Fondo decorativo al hover */}
    <div class="absolute inset-0 bg-gradient-to-br from-primary-light/5 to-transparent dark:from-primary-dark/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />
    
    {/* Badge de verificación */}
    {isVerified && (
        <div class="absolute top-4 right-4 flex items-center gap-1 text-xs font-semibold text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/20 px-2 py-1 rounded-full z-10">
            <Icon name="lucide:shield-check" width={14} height={14} />
            Verificado
        </div>
    )}
    
    {/* 🖼️ IMAGEN CLICKEABLE — Click aquí te lleva a la credencial */}
    <a 
        href={credentialUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="relative w-full aspect-[4/3] rounded-xl overflow-hidden bg-gray-50 dark:bg-n400 group/img cursor-pointer"
        title={`Ver credencial de ${name}`}
    >
        <img 
            src={image} 
            alt={`Certificación ${name}`}
            class="w-full h-full object-cover transition-transform duration-500 group-hover/img:scale-105"
            loading="lazy"
        />
        
        {/* Overlay al hover con ícono de enlace */}
        <div class="absolute inset-0 bg-black/0 group-hover/img:bg-black/30 transition-colors duration-300 flex items-center justify-center">
            <div class="opacity-0 group-hover/img:opacity-100 transition-opacity duration-300 flex items-center gap-2 text-white font-medium bg-black/50 px-4 py-2 rounded-full backdrop-blur-sm">
                <Icon name="lucide:external-link" width={18} height={18} />
                Ver credencial
            </div>
        </div>
    </a>
    
    {/* Contenido */}
    <div class="flex flex-col gap-2 relative z-10">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white">
            {name}
        </h3>
        
        {/* Meta info */}
        {(issuer || date) && (
            <div class="flex flex-wrap items-center gap-2 text-xs text-gray-500 dark:text-n300">
                {issuer && (
                    <span class="flex items-center gap-1">
                        <Icon name="lucide:building-2" width={12} height={12} />
                        {issuer}
                    </span>
                )}
                {date && (
                    <span class="flex items-center gap-1">
                        <Icon name="lucide:calendar" width={12} height={12} />
                        {date}
                    </span>
                )}
            </div>
        )}
        
        {/* Nivel */}
        {level && levelConfig[level] && (
            <span class={`inline-flex w-fit items-center gap-1 text-xs font-medium px-2.5 py-0.5 rounded-full ${levelConfig[level].color}`}>
                <Icon name="lucide:bar-chart-3" width={12} height={12} />
                {levelConfig[level].label}
            </span>
        )}
        
        {/* Descripción */}
        {showDescription && (
            <p class="text-sm text-gray-600 dark:text-n200 leading-relaxed">
                {description}
            </p>
        )}
        
        {/* Tags */}
        {tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-1">
                {tags.map((tag) => (
                    <span class="text-[11px] px-2 py-0.5 rounded-md bg-gray-100 dark:bg-n400 text-gray-600 dark:text-n300 font-medium">
                        {tag}
                    </span>
                ))}
            </div>
        )}
    </div>
</div>
