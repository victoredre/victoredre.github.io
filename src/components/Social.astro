---
// components imports
import {Icon} from "astro-icon/components";

// config import
import {SOCIALS} from '@/config';

---

<div class={'flex gap-2 md:gap-4'}>
    {
        SOCIALS.map((networkS) => (
            networkS.show && (
                    
                            href={networkS.url}
                            target="_blank"
                            aria-label={networkS.name + "-link"}
                    >
                        <Icon name={networkS.icon} class="text-n900 dark:text-n200"/>
                    </a>
            )
        ))
    }
</div>
