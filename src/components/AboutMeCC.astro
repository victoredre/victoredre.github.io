---
// data imports
import workExperience from "@/data/Jobs.ts"
import education from "@/data/education.ts"
import languages from "../data/languages.ts"
import hardSkills from "@/data/hardSkills"
import softSkills from "@/data/softSkills"

// component imports
import JobDetails from "./JobDetails.astro";
import EduDetail from "./EduDetail.astro";
import SkillCard from "./SkillCard.astro";

// config import
import {ME} from '@/config';

---

<div class="relative flex flex-col gap-2 text-n700 dark:text-n400 w-full mt-100 px-4">
    {/*Description or About me -- Section*/}
    <h2 class="text-4xl font-bold mb-2">Perfil Profesional</h2>
    <div class="flex flex-col gap-2">
    <div class="mb-1">
        <p>
            {ME.aboutMe}
        </p>
    </div>
    {/*Experiencia*/}
    <div class="mb-1">
        <h2 class="text-4xl font-bold mb-2">Experiencia</h2>
        <div class="flex flex-col gap-6">
            {workExperience.map((job) => (
                    <JobDetails jobData={job}/>
            ))}
        </div>
    </div>
    {/*Educación*/}
    <div class="mb-4">
        <h2 class="text-4xl font-bold mb-2">Educación</h2>
        <div class="flex flex-col gap-6">
            {education.map((edu) => (
                    <EduDetail eduData={edu}/>
            ))}
        </div>
    </div>
    {/*Competencias*/}
    <div class="mb-4">
        <h2 class="text-4xl font-bold mb-2">Competencias</h2>
        <div class="grid grid-cols-3 md:grid-cols-5 gap-6">
            {hardSkills.map((skill) => (
                    <SkillCard {...skill} showDescription={true}/>
            ))}
        </div>
    </div>
    {/*Certificaciones*/}
    <div class="mb-4">
        <h2 class="text-4xl font-bold mb-2">Certificaciones</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            {softSkills.map((skill) => (
                    <SkillCard {...skill} showDescription={false}/>
            ))}
        </div>
    </div>
    {/*Languages section*/}
    <div class="mb-4">
        <h2 class="text-4xl font-bold mb-2">Languages</h2>
        <div class="flex flex-col gap-6">
            {
                languages.map((lang) => (
                    lang.show ? <p>{lang.name} - {lang.level}</p> : null
                ))
            }
        </div>
    </div>
</div>
