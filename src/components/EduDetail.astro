---
interface Edu {
    title: string;
    school: string;
    location: string;
    startDate: string;
    endDate?: string;
    description: string;
    currentUni: boolean;
    logo?: string; // nueva propiedad
}

const {eduData} = Astro.props;
const {
    title,
    school,
    location,
    startDate,
    endDate,
    description,
    currentUni,
    logo
} = eduData as Edu;
---

<div class="flex gap-4">
    {logo && (
        <img
            src={logo}
            alt={`${school} logo`}
            class="w-12 h-12 object-contain rounded-md shrink-0"
        />
    )}
    <div class="flex flex-col gap-1">
        <Badge className="bg-primary-light dark:bg-primary-dark w-fit rounded-md">
            {formatDatetime(startDate)} - {currentUni ? "Present" : formatDatetime(endDate)}
        </Badge>
        <h3 class="text-2xl font-bold">{title}</h3>
        <div class="flex gap-1">
            <p>{school}</p>
            <span>/</span>
            <p>{location}</p>
        </div>
        <p>{description}</p>
    </div>
</div>
